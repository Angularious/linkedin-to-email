# Orthogonal API (server-side only)
ORTHOGONAL_API_KEY=

# Supabase (server-side only — use the service_role key, never the anon key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile — REQUIRED in production (the API fails closed without it)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Hard global spend ceiling over a rolling 24h, in cents. Default 2500 ($25).
DAILY_BUDGET_CENTS=2500

# Canonical site URL — used for OpenGraph / social preview links.
NEXT_PUBLIC_SITE_URL=https://linkedin-to-email.vercel.app
